#
# управление громкостью
#

# уменьшить громкость
@XF86AudioLowerVolume
    $HOME/.config/bspwm/bspwm-volume.pactl.sh down

# увеличить громкость
@XF86AudioRaiseVolume
    $HOME/.config/bspwm/bspwm-volume.pactl.sh up

# замьютить
@XF86AudioMute
    $HOME/.config/bspwm/bspwm-volume.pactl.sh mute

#
# скриншоты
#

Print
    shot

super + Scroll_Lock
    xtrlock -f -b

super + backslash
    latex2unicode

super + s
    switch-audio.bb "7 - vendor 0x0a12 B10" "1 - NVIDIA"
