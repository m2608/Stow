# уменьшить громкость
@XF86AudioLowerVolume
    $HOME/.config/bspwm/bspwm-volume.wpctl.sh down

# увеличить громкость
@XF86AudioRaiseVolume
    $HOME/.config/bspwm/bspwm-volume.wpctl.sh up

# замьютить
@XF86AudioMute
    $HOME/.config/bspwm/bspwm-volume.wpctl.sh mute

super + @XF86AudioLowerVolume
    brightness.bb -5%

super + @XF86AudioRaiseVolume
    brightness.bb +5%

super + @XF86AudioMute
    brightness.bb 20%

super + Scroll_Lock
    lock

Print
    shot

super + d
    sh $HOME/.config/bspwm/bspwm-display.sh

super + s
    switch-audio.bb "(Rembrandt|B10)"

